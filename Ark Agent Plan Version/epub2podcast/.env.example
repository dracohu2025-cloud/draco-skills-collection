# =============================================================================
# Ark Agent Plan 专用版本 - 环境变量配置
# 与 Seedream/Seedance 共享火山引擎技术栈
# =============================================================================

# -----------------------------------------------------------------------------
# 火山引擎统一认证（与 Seedream/Seedance 共享）
# -----------------------------------------------------------------------------
# 这是唯一需要配置的密钥，同时用于：
#   - 火山引擎 TTS（本项目）
#   - Seedream 图片生成
#   - Seedance 视频生成
# -----------------------------------------------------------------------------
VOLCENGINE_ACCESS_TOKEN=your_volcengine_access_token_here
VOLCENGINE_TTS_APP_ID=your_tts_app_id_here

# 可选：TTS 2.0 Resource ID（有默认值，通常不需要修改）
VOLCENGINE_TTS_2_RESOURCE_ID=seed-tts-2.0

# -----------------------------------------------------------------------------
# 其他服务（仅用于备用，优先使用火山引擎）
# -----------------------------------------------------------------------------
# Google Gemini（仅作为 TTS fallback，不推荐）
# GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter（仅作为 LLM fallback，不推荐）
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ElevenLabs（仅作为 TTS fallback，不推荐）
# 11LABS_API_KEY=your_elevenlabs_api_key_here

# -----------------------------------------------------------------------------
# Agent Plan 原生能力开关
# -----------------------------------------------------------------------------
# 启用后优先使用 Agent Plan 原生工具调用（推荐）
AGENT_PLAN_NATIVE_TTS=true
AGENT_PLAN_NATIVE_IMAGE=true
AGENT_PLAN_NATIVE_VIDEO=true
