# BrowserUse API key. Either name works.
BROWSER_USE_API_KEY=
# BROWSERUSE_API_KEY=

# Optional defaults
BROWSER_USE_PROXY_COUNTRY=hk
BROWSER_USE_TIMEOUT=240
BROWSER_USE_WAIT_MS=8000

# Optional: tune Feishu doc search fallback if you customize the publisher later.
WECHAT_BROWSERUSE_SEARCH_RETRIES=6
WECHAT_BROWSERUSE_SEARCH_DELAY=3
