# Optional overrides for camofox-browser bootstrap

# Local service port
# CAMOFOX_PORT=9377

# Custom clone target for camofox-browser
# CAMOFOX_BROWSER_REPO=~/.hermes/camofox-browser

# Custom camofox-browser git source
# CAMOFOX_BROWSER_GIT_URL=https://github.com/jo-inc/camofox-browser.git

# Bootstrap timeout in seconds (clone / npm install)
# CAMOFOX_INSTALL_TIMEOUT=1800

# Health check wait window in seconds after startup
# CAMOFOX_HEALTH_WAIT_SECONDS=120
